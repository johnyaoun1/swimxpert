# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=Host=...;Port=5432;Database=...;Username=...;Password=...

# ─── JWT ────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate one with:
#   openssl rand -base64 48
JWT_KEY=your-production-secret-key-min-32-chars
JWT_ISSUER=SwimXpert.Api
JWT_AUDIENCE=SwimXpert.Client
JWT_EXPIRY_MINUTES=60

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─── Host filtering ─────────────────────────────────────────────────────────
# Set to your production domain to prevent host-header injection attacks.
# Example: swimxpert.com  or  swimxpert.com,www.swimxpert.com
ALLOWED_HOSTS=yourdomain.com

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.yourmailprovider.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your-smtp-password

# ─── First admin account (runs only once on first startup) ──────────────────
# INITIAL_ADMIN_EMAIL=admin@yourdomain.com
# INITIAL_ADMIN_PASSWORD=change-me-immediately

# ─── File uploads (Cloudinary — required for persistent storage on Railway) ──
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
